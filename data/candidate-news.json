[\n  {\n    \"id\": \"cn-1772028154020-new-braunfels-council-meeting-recap-political-foundation-rem\",\n    \"date\": \"2026-02-25T14:02:34\",\n    \"title\": \"New Braunfels Council Meeting Recap: Political Foundation Remains Strong\",\n    \"summary\": \"Chase Taylor's Substack analysis of the recent New Braunfels City Council meeting highlights that the political foundation of Comal County remains conservative, with local elections determining the city's future direction rather than newcomers from liberal areas. The piece encourages voters to support candidates aligning with their vision for the city.\",\n    \"source\": \"Chase Taylor Substack\",\n    \"sourceUrl\": \"https://chasetaylor1.substack.com/p/new-braunfels-council-condensed-7b8\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"city-council\",\n      \"comal-county\",\n      \"local-elections\",\n      \"conservative\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771801359848-stuart-hansmann-appointed-interim-tax-assessor-collector-aft\",\n    \"date\": \"2026-02-22T23:02:39\",\n    \"title\": \"Stuart Hansmann Appointed Interim Tax Assessor-Collector After Hoyt's County Judge Run\",\n    \"summary\": \"Stuart Hansmann was appointed as interim tax assessor-collector following Kristen Hoyt's decision to run for county judge. Hansmann, born and raised in Comal County, is a Texas A&M graduate with 30 years of experience in commercial, real estate and construction finance. The appointment fills the vacancy created when Hoyt stepped down to pursue the county's top elected position.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-unopposed-incumbent-candidates/article_1ba26de1-bf4c-4cb4-a88a-8b5d4f9a014d.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"stuart-hansmann\",\n      \"kristen-hoyt\",\n      \"county-judge\",\n      \"tax-assessor-collector\",\n      \"comal-county\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771768935959-city-council-addresses-controversial-zoning-amid-mayoral-cam\",\n    \"date\": \"2026-02-22T14:02:15\",\n    \"title\": \"City Council Addresses Controversial Zoning Amid Mayoral Campaign\",\n    \"summary\": \"New Braunfels City Council voted on controversial zoning changes for a 38-acre housing development, with mayoral candidate Angela Allen among the vocal opponents. Allen, who serves on the Planning Commission, has made opposition to the zoning change a key part of her campaign platform. The development has drawn significant community opposition over traffic and infrastructure concerns.\",\n    \"source\": \"KSAT\",\n    \"sourceUrl\": \"https://www.ksat.com/news/local/2026/02/18/new-braunfels-city-council-to-decide-on-controversial-zoning-change-for-proposed-housing-project/\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"angela-allen\",\n      \"zoning\",\n      \"mayor\",\n      \"planning-commission\",\n      \"community-opposition\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771714907192-state-senator-donna-campbell-endorses-kristen-hoyt-for-count\",\n    \"date\": \"2026-02-21T23:01:47\",\n    \"title\": \"State Senator Donna Campbell Endorses Kristen Hoyt for County Judge\",\n    \"summary\": \"Texas State Senator Donna Campbell (R-District 25) has endorsed Kristen Hoyt in the Republican primary for Comal County Judge. The endorsement comes as part of Hoyt's growing coalition of law enforcement and political support, which also includes endorsements from all four Comal County Constables, the Comal County Deputy Sheriff's Association, Bulverde Spring Branch Conservative Republicans, and New Braunfels Young Republicans. Hoyt, the former Tax Assessor-Collector, is running on a platform of efficiency, transparency, and fiscal responsibility in the March 3 primary election.\",\n    \"source\": \"My Canyon Lake\",\n    \"sourceUrl\": \"https://mycanyonlake.com/hoyt-promises-efficiency-transparency-and-conservative-results-for-taxpayers-in-bid-for-county-judge/\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"donna-campbell\",\n      \"kristen-hoyt\",\n      \"endorsement\",\n      \"county-judge\",\n      \"state-senator\",\n      \"republican-primary\",\n      \"2026-election\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771596116557-new-braunfels-officially-calls-may-election-with-complete-ca\",\n    \"date\": \"2026-02-20T14:01:56\",\n    \"title\": \"New Braunfels Officially Calls May Election with Complete Candidate Slate\",\n    \"summary\": \"New Braunfels City Council officially called the May 2026 election for mayor and two council seats on February 9. Election day is set for May 2, with early voting April 20-25 and April 27-28. Incumbent Mayor Neal Linnartz faces three challengers: Michael French (communications), Angela Allen (planning commission member), and business owner Jonathon Fraizer. Council District 5's Mary Ann Labowski faces planning commissioner Chase Taylor, while District 6's April Ryan faces retail associate Nikki Shaw and engineer Steven Voges. Voter registration deadline is April 2.\",\n    \"source\": \"Community Impact\",\n    \"sourceUrl\": \"https://communityimpact.com/san-antonio/new-braunfels/election/2026/02/19/new-braunfels-city-council-calls-may-election-for-mayor-2-council-member-seats/\",\n    \"archiveUrl\": \"articles/archive/nb-may-election-complete-candidate-slate.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"mayor\",\n      \"city-council\",\n      \"election-dates\",\n      \"2026-election\"\n    ],\n    \"image\": \"images/thumbs/cn-1771596116557-new-braunfels-officially-calls-may-election-with-complete-ca.png\"\n  },\n  {\n    \"id\": \"cn-1771509774658-chamber-hosts-candidate-forum-ahead-of-march-primary\",\n    \"date\": \"2026-02-19T14:02:54\",\n    \"title\": \"Chamber Hosts Candidate Forum Ahead of March Primary\",\n    \"summary\": \"New Braunfels Chamber of Commerce hosted a candidate forum featuring commissioners court candidates for both Comal and Guadalupe counties ahead of the March primary election. All commissioners court candidates participating were Republican. The forum also included candidates for Comal County Judge and Guadalupe County Judge positions.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/news/new-braunfels-chamber-of-commerce-hosts-candidate-forum-ahead-of-march-primary-election/article_7c68ab9b-431f-48a2-b2cc-c8d93a8f7f64.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"chamber-of-commerce\",\n      \"candidate-forum\",\n      \"commissioners-court\",\n      \"county-judge\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771509767606-comal-county-justice-of-peace-candidates-announced-for-preci\",\n    \"date\": \"2026-02-19T14:02:47\",\n    \"title\": \"Comal County Justice of Peace Candidates Announced for Precincts 3 & 4\",\n    \"summary\": \"Early voting for the 2026 primary elections begins February 17, with Election Day March 3. Comal County Justice of the Peace races for Precincts 3 & 4 feature multiple candidates. Early voting information and candidate details are available through Comal County elections office.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-candidates-for-comal-county-justice-of-the-peace-precincts-3-4/article_079693cf-66ee-4070-8c14-195b5866b6dc.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"justice-of-peace\",\n      \"comal-county\",\n      \"early-voting\",\n      \"primary-election\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771459113421-kristen-hoyt-earns-unanimous-law-enforcement-endorsement-for\",\n    \"date\": \"2026-02-18T23:58:33\",\n    \"title\": \"Kristen Hoyt Earns Unanimous Law Enforcement Endorsement for Comal County Judge\",\n    \"summary\": \"Kristen Hoyt, running for Comal County Judge in the March 3 Republican primary, has secured endorsements from all four Comal County Constables and the Comal County Deputy Sheriff's Association. Hoyt, a former Tax Assessor-Collector who left that position to run for judge, is campaigning on a platform of fully funding public safety and fiscally responsible governance. Early voting runs through February 27.\",\n    \"source\": \"Campaign Mailer\",\n    \"sourceUrl\": \"https://kristenhoyt.com\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"kristen-hoyt\",\n      \"county-judge\",\n      \"law-enforcement\",\n      \"comal-county\",\n      \"republican-primary\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771459105669-trump-endorses-mark-tex-teixeira-for-texas-21st-congressiona\",\n    \"date\": \"2026-02-18T23:58:25\",\n    \"title\": \"Trump Endorses Mark 'Tex' Teixeira for Texas 21st Congressional District\",\n    \"summary\": \"President Donald Trump endorsed Mark 'Tex' Teixeira on February 4, 2026 to succeed Chip Roy in Texas Congressional District 21. Teixeira, a former MLB All-Star with five Gold Gloves and a World Series Championship, also holds the endorsement of Governor Greg Abbott. He is running on an America First platform focused on border security, cutting spending, and energy dominance. Early voting begins February 17.\",\n    \"source\": \"Trump Social / Campaign Mailer\",\n    \"sourceUrl\": \"https://texforcongress.com\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"mark-teixeira\",\n      \"tx-21\",\n      \"trump-endorsement\",\n      \"congressional-race\",\n      \"chip-roy\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771455697256-meet-the-unopposed-and-incumbent-candidates\",\n    \"date\": \"2026-02-18T23:01:37\",\n    \"title\": \"Meet the Unopposed and Incumbent Candidates\",\n    \"summary\": \"Several local candidates are running unopposed, including interim Tax Assessor-Collector who was appointed after Kristen Hoyt left to run for county judge. Hansmann, a Comal County native with 30 years in finance, brings commercial real estate and construction finance experience.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-unopposed-incumbent-candidates/article_1ba26de1-bf4c-4cb4-a88a-8b5d4f9a014d.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"unopposed-candidates\",\n      \"tax-assessor\",\n      \"interim-appointment\",\n      \"kristen-hoyt\",\n      \"hansmann\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771455689697-hundreds-gather-at-wurstfest-to-honor-judge-krause\",\n    \"date\": \"2026-02-18T23:01:29\",\n    \"title\": \"Hundreds Gather at Wurstfest to Honor Judge Krause\",\n    \"summary\": \"Community members filled the Wursthalle at Wurstfest grounds to honor the life of late Comal County Judge Sherman Krause. The memorial service brought together hundreds under colorful string lights to celebrate Krause's legacy of quiet service to the county.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/news/serve-quietly-comal-county-community-gathers-at-wurstfest-grounds-to-honor-judge-krause/article_222b80dc-c41b-4640-8fa8-2c6d390c72cb.html\",\n    \"category\": \"county-government\",\n    \"tags\": [\n      \"sherman-krause\",\n      \"memorial\",\n      \"county-judge\",\n      \"wurstfest\",\n      \"community\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771423324110-new-braunfels-chamber-hosts-candidate-forum-ahead-of-primary\",\n    \"date\": \"2026-02-18T14:02:04\",\n    \"title\": \"New Braunfels Chamber Hosts Candidate Forum Ahead of Primary\",\n    \"summary\": \"New Braunfels Chamber of Commerce hosted a candidate forum ahead of the March primary election. Steve Minus shared his endorsement from the New Braunfels Young Republicans and Bexar County Commissioner Grant Moody along with his background as a Comal ISD school board member.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/news/new-braunfels-chamber-of-commerce-hosts-candidate-forum-ahead-of-march-primary-election/article_7c68ab9b-431f-48a2-b2cc-c8d93a8f7f64.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"candidate-forum\",\n      \"chamber-of-commerce\",\n      \"steve-minus\",\n      \"endorsements\",\n      \"2026-primary\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771423317891-kristen-hoyt-promises-efficiency-transparency-for-county-jud\",\n    \"date\": \"2026-02-18T14:01:57\",\n    \"title\": \"Kristen Hoyt Promises Efficiency, Transparency for County Judge\",\n    \"summary\": \"Former Comal County Tax Assessor-Collector Kristen Hoyt campaigns on efficiency, transparency and conservative results for taxpayers in her bid for County Judge. While her commitment to shielding Comal County from developers proved popular, counties have very limited land-use authority.\",\n    \"source\": \"My Canyon Lake\",\n    \"sourceUrl\": \"https://mycanyonlake.com/hoyt-promises-efficiency-transparency-and-conservative-results-for-taxpayers-in-bid-for-county-judge/\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-judge\",\n      \"kristen-hoyt\",\n      \"transparency\",\n      \"development\",\n      \"2026-election\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771423312207-county-officials-honor-judge-krause-s-memory-discuss-interim\",\n    \"date\": \"2026-02-18T14:01:52\",\n    \"title\": \"County Officials Honor Judge Krause's Memory, Discuss Interim Appointment\",\n    \"summary\": \"Comal County officials honor the memory of late County Judge Sherman Krause. Commissioners expect to discuss appointing an interim county judge during their Feb. Three candidates are on the March ballot: former Tax Assessor-Collector Kristen Hoyt, business owner Deb Hindman, and firefighter Kayne Parrish.\",\n    \"source\": \"San Antonio Express-News\",\n    \"sourceUrl\": \"https://www.expressnews.com/hill-country/article/comal-judge-death-krause-new-braunfels-court-texas-21349781.php\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-judge\",\n      \"interim-appointment\",\n      \"kristen-hoyt\",\n      \"deb-hindman\",\n      \"kayne-parrish\",\n      \"2026-election\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771423305538-2026-elections-meet-your-candidates-for-comal-county-clerk\",\n    \"date\": \"2026-02-18T14:01:45\",\n    \"title\": \"2026 ELECTIONS: Meet your candidates for Comal County Clerk\",\n    \"summary\": \"Four Republican candidates are vying for the open Comal County Clerk seat being vacated by Bobbie Koepp: Ryan Bourbon-Stuart, Garrison Maurer, LeAnn Miller, and Romelle 'Melle' Walkup. Election day is March 3.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-candidates-for-comal-county-clerk/article_b4388deb-8434-421d-9621-62733f26f205.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-clerk\",\n      \"republican-primary\",\n      \"2026-election\",\n      \"comal-county\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771369297355-2026-elections-meet-your-candidates-for-comal-county-justice\",\n    \"date\": \"2026-02-17T23:01:37\",\n    \"title\": \"2026 ELECTIONS: Meet your candidates for Comal County Justice of the Peace Precincts 3 & 4\",\n    \"summary\": \"Early voting for the 2026 primary elections will begin next Tuesday, Feb. 17, and election day will be March 3. On the ballot for Comal County Justice of the Peace,\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-candidates-for-comal-county-justice-of-the-peace-precincts-3-4/article_079693cf-66ee-4070-8c14-195b5866b6dc.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"justice-of-peace\",\n      \"precinct-3\",\n      \"precinct-4\",\n      \"2026-election\"\n    ]\n  },\n  {\n    \"id\": \"cn-1771346883102-2026-elections-meet-your-comal-county-commissioner-candidate\",\n    \"date\": \"2026-02-17T16:48:03\",\n    \"title\": \"2026 ELECTIONS: Meet your Comal County Commissioner candidates\",\n    \"summary\": \"One of his priorities as county commissioner is to improve the taxpayer experience for all county residents, particularly on the outskirts like Garden Ridge and Bulverde, which he said haven't been supported as much as other precincts thus far. Another goal for Stratemann is to carry on the legacy of Comal County.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-comal-county-commissioner-candidates/article_89b2fe25-4cc3-49a9-be06-5ace70620f86.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-commissioner\",\n      \"comal-county\",\n      \"stratemann\"\n    ],\n    \"relatedCandidate\": \"john-stratemann\"\n  },\n  {\n    \"id\": \"cn-1771346875499-candidate-filing-for-city-council-positions-now-open-to-new-\",\n    \"date\": \"2026-02-17T16:47:55\",\n    \"title\": \"Candidate filing for city council positions now open to New Braunfels residents\",\n    \"summary\": \"City of New Braunfels residents seeking to serve the public can now file to run for city council for the 2026 general election. Filing is open now through Feb.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/candidate-filing-for-city-council-positions-now-open-to-new-braunfels-residents/article_73a2649f-6b67-4149-ad46-95554b687590.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"candidate-filing\",\n      \"mayor\",\n      \"city-council\"\n    ]\n  },\n  {\n    \"id\": \"michael-french-draws-45-to-first-mayoral-town-hall\",\n    \"date\": \"2026-02-16T21:05:22.502Z\",\n    \"title\": \"Michael French Draws 45 to First Mayoral Town Hall\",\n    \"summary\": \"Mayoral candidate Michael French drew 45 residents to his first campaign town hall at Coopers Pit Bar-B-Que, fielding questions about city issues and his vision for New Braunfels. French is one of five candidates in the mayoral race, with early voting beginning February 17.\",\n    \"source\": \"Hill Country Sentinel\",\n    \"sourceUrl\": \"articles/michael-french-draws-45-to-first-mayoral-town-hall.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"mayor\",\n      \"michael-french\",\n      \"town-hall\"\n    ],\n    \"image\": \"articles/images/michael-french-draws-45-to-first-mayoral-town-hall.png\",\n    \"relatedCandidate\": \"michael-french\"\n  },\n  {\n    \"id\": \"cn-1771023777416-tom-clark-seeks-fourth-term-as-justice-of-peace-precinct-1\",\n    \"date\": \"2026-02-13T23:02:57\",\n    \"title\": \"Tom Clark Seeks Fourth Term as Justice of Peace Precinct 1\",\n    \"summary\": \"Justice of Peace Tom Clark, a third-generation Comal County resident who was born and raised in New Braunfels, is seeking his fourth term representing Precinct 1. Early voting begins February 17 with election day March 3.\",\n    \"source\": \"Herald-Zeitung\",\n    \"relatedCandidate\": \"tom-clark\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-candidates-for-comal-county-justice-of-the-peace-precincts-1-2/article_4af96dba-d801-4ae8-8cbd-f14aa23ec29d.html\",\n    \"archiveUrl\": \"articles/archive/tom-clark-jp-precinct-1-fourth-term.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"justice-of-peace\",\n      \"precinct-1\",\n      \"tom-clark\",\n      \"2026-election\",\n      \"incumbent\"\n    ],\n    \"image\": \"images/thumbs/cn-1771023777416-tom-clark-seeks-fourth-term-as-justice-of-peace-precinct-1.jpg\"\n  },\n  {\n    \"id\": \"cn-1770997423382-christi-craddick-campaigns-for-texas-comptroller-in-republic\",\n    \"date\": \"2026-02-13T15:43:43\",\n    \"title\": \"Christi Craddick Campaigns for Texas Comptroller in Republican Primary\",\n    \"summary\": \"Current Railroad Commissioner Christi Craddick is running for Texas Comptroller, with campaign mailers reaching Comal County voters. Early voting Feb 17-27, election day March 3.\",\n    \"source\": \"Campaign Mailer\",\n    \"sourceUrl\": \"https://christicraddickforcomptroller.com\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"comptroller\",\n      \"christi-craddick\",\n      \"republican-primary\",\n      \"statewide\",\n      \"2026\"\n    ],\n    \"image\": \"images/thumbs/cn-1770997423382-christi-craddick-campaigns-for-texas-comptroller-in-republic.jpg\"\n  },\n  {\n    \"id\": \"cn-1770997416945-comal-county-clerk-race-four-republicans-compete-in-march-3-\",\n    \"date\": \"2026-02-13T15:43:36\",\n    \"title\": \"Comal County Clerk Race: Four Republicans Compete in March 3 Primary\",\n    \"summary\": \"Four Republican candidates are vying for the open Comal County Clerk seat being vacated by Bobbie Koepp: Ryan Bourbon-Stuart, Garrison Maurer, LeAnn Miller, and Romelle 'Melle' Walkup. Early voting begins Feb 17.\",\n    \"source\": \"Campaign Mailer / My Canyon Lake\",\n    \"sourceUrl\": \"https://mycanyonlake.com/comal-county-candidates-file-to-run-for-local-office-in-march-3-2026-primary-elections/\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-clerk\",\n      \"republican-primary\",\n      \"leann-miller\",\n      \"2026\",\n      \"comal-county\"\n    ],\n    \"image\": \"images/thumbs/cn-1770997416945-comal-county-clerk-race-four-republicans-compete-in-march-3-.jpg\"\n  },\n  {\n    \"id\": \"cn-1770997410907-former-mlb-star-mark-teixeira-campaigns-for-tx-21-congressio\",\n    \"date\": \"2026-02-13T15:43:30\",\n    \"title\": \"Former MLB Star Mark Teixeira Campaigns for TX-21 Congressional Seat\",\n    \"summary\": \"Former New York Yankees first baseman Mark 'Tex' Teixeira is running to succeed Rep. Chip Roy in Texas Congressional District 21, which includes Comal County. His campaign mailer emphasizes border security, defending life and 2nd Amendment rights, banning men from women's sports, and standing with President Trump.\",\n    \"source\": \"Campaign Mailer / San Antonio Express-News\",\n    \"sourceUrl\": \"https://teixeiraforcongress.com\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"congress\",\n      \"tx-21\",\n      \"mark-teixeira\",\n      \"republican-primary\",\n      \"2026\"\n    ]\n  },\n  {\n    \"id\": \"cn-1770937286104-new-braunfels-software-engineer-paul-rojas-runs-for-us-house\",\n    \"date\": \"2026-02-12T23:01:26\",\n    \"title\": \"New Braunfels Software Engineer Paul Rojas Runs for US House District 21\",\n    \"summary\": \"Paul Rojas, a cybersecurity expert and software engineer from New Braunfels, is running in the Republican primary for US House District 21 to replace Chip Roy. The Austin American-Statesman editorial board highlighted his expertise on AI's effects on Texas jobs, land, and water.\",\n    \"source\": \"Austin American-Statesman\",\n    \"sourceUrl\": \"https://www.statesman.com/opinion/editorials/article/betts-stands-us-house-21-gop-field-replace-roy-21334201.php\",\n    \"archiveUrl\": \"articles/archive/rojas-us-house-21-primary.html\",\n    \"category\": \"legislation\",\n    \"tags\": [\n      \"paul-rojas\",\n      \"us-house\",\n      \"district-21\",\n      \"cybersecurity\",\n      \"technology\",\n      \"2026-election\"\n    ],\n    \"image\": \"images/thumbs/cn-1770937286104-new-braunfels-software-engineer-paul-rojas-runs-for-us-house.jpg\"\n  },\n  {\n    \"id\": \"cn-1770921846507-comal-county-judge-candidates-profile-available\",\n    \"date\": \"2026-02-12T18:44:06\",\n    \"title\": \"Comal County Judge Candidates Profile Available\",\n    \"summary\": \"Candidate profile for Comal County Judge race includes Parrish, who cites Christian values and politics in the Bible as motivation for running. Position became vacant after Judge Sherman Krause's death.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-candidates-for-comal-county-judge/article_f9b6d3fa-ccb9-4047-8161-4f5fbaec40dd.html\",\n    \"archiveUrl\": \"articles/archive/county-judge-candidates-profile.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"county-judge\",\n      \"2026-election\",\n      \"vacancy\"\n    ],\n    \"image\": \"images/thumbs/cn-1770921846507-comal-county-judge-candidates-profile-available.jpg\"\n  },\n  {\n    \"id\": \"cn-1770921832718-comal-county-commissioner-precinct-2-candidates-announced\",\n    \"date\": \"2026-02-12T18:43:52\",\n    \"title\": \"Comal County Commissioner Precinct 2 Candidates Announced\",\n    \"summary\": \"Early voting begins February 17 for the Comal County Commissioner Precinct 2 race featuring candidates John Stratemann, Steve Minus, and Steven Rollins. Election day is March 3, 2026.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/2026-elections-meet-your-comal-county-commissioner-candidates/article_89b2fe25-4cc3-49a9-be06-5ace70620f86.html\",\n    \"archiveUrl\": \"articles/archive/commissioner-precinct-2-candidates.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"commissioner\",\n      \"precinct-2\",\n      \"2026-election\"\n    ],\n    \"image\": \"images/thumbs/cn-1770921832718-comal-county-commissioner-precinct-2-candidates-announced.jpg\"\n  },\n  {\n    \"id\": \"cn-001\",\n    \"date\": \"2026-02-10T12:00:00\",\n    \"title\": \"County Judge Seat Vacant After Passing of Sherman Krause\",\n    \"summary\": \"Comal County Judge Sherman Krause passed away on February 7, 2026, leaving the county's top administrative position vacant. Commissioners Court will need to appoint a replacement or call a special election.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/news/comal-county-mourns-the-passing-of-judge-sherman-krause/article_8d1f4987-d8dc-42ab-a706-dd4a40f3ae24.html\",\n    \"archiveUrl\": \"articles/archive/county-judge-seat-vacant.html\",\n    \"category\": \"county-government\",\n    \"tags\": [\n      \"county-judge\",\n      \"vacancy\",\n      \"commissioners-court\"\n    ],\n    \"image\": \"images/thumbs/cn-001.jpg\"\n  },\n  {\n    \"id\": \"cn-002\",\n    \"date\": \"2026-02-08T12:00:00\",\n    \"title\": \"Five Candidates File for New Braunfels Mayor\",\n    \"summary\": \"The New Braunfels mayoral race is shaping up with five candidates: incumbent Neal Linnartz, Michael French, Bradley Porter, Angela Allen, and Jonathon Frazier. Filing deadline is February 13, 2026.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/candidate-filing-for-city-council-positions-now-open-to-new-braunfels-residents/article_73a2649f-6b67-4149-ad46-95554b687590.html\",\n    \"archiveUrl\": \"articles/archive/new-braunfels-mayor-candidates-file.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"mayor\",\n      \"new-braunfels\",\n      \"2026-election\"\n    ],\n    \"relatedCandidate\": \"neal-linnartz\",\n    \"image\": \"images/thumbs/cn-002.jpg\"\n  },\n  {\n    \"id\": \"cn-003\",\n    \"date\": \"2026-02-05T12:00:00\",\n    \"title\": \"Rep. Carrie Isaac Files Transportation Infrastructure Bill\",\n    \"summary\": \"State Representative Carrie Isaac (R-District 73) filed a bill aimed at improving transportation infrastructure in the I-35 corridor through Comal County, citing rapid population growth as the driving factor.\",\n    \"source\": \"Texas Tribune\",\n    \"sourceUrl\": \"https://www.texastribune.org/tag/carrie-isaac/\",\n    \"archiveUrl\": \"articles/archive/carrie-isaac-transportation-bill.html\",\n    \"category\": \"legislation\",\n    \"tags\": [\n      \"state-legislature\",\n      \"transportation\",\n      \"i-35\"\n    ],\n    \"relatedCandidate\": \"carrie-isaac\"\n  },\n  {\n    \"id\": \"cn-2026-02-25-nikki-shaw-launch\",\n    \"date\": \"2026-02-25T17:01:00\",\n    \"title\": \"Combat veteran Nikki Shaw launches campaign for City Council District 6\",\n    \"summary\": \"Nikki Shaw, a combat veteran, has launched her campaign for New Braunfels City Council District 6. She emphasizes accountability, teamwork, and mission-focused leadership, criticizing current governance. Her platform focuses on common-sense growth, protecting education, supporting seniors and veterans, and defending the city's character.\",\n    \"source\": \"Herald-Zeitung\",\n    \"sourceUrl\": \"https://herald-zeitung.com/election/combat-veteran-nikki-shaw-launches-campaign-for-city-council-district-6/article_2d786922-3044-4e05-af3c-1a2e993c9a8a.html\",\n    \"category\": \"elections\",\n    \"tags\": [\n      \"nikki-shaw\",\n      \"district-6\",\n      \"campaign-launch\",\n      \"veteran\",\n      \"city-council\"\n    ]\n  }\n]